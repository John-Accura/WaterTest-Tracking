# Neon Postgres connection string (use the pooled one from Neon dashboard)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Auth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-32-byte-base64"

# Default admin to seed on first run
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="changeMeNow!"
SEED_ADMIN_NAME="Admin"
